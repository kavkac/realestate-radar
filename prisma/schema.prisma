generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// PostGIS geometry columns will be added in Phase 2 via raw SQL migrations

model Property {
  id           String  @id @default(cuid())
  koId         Int
  stStavbe     Int
  stDelaStavbe Int?
  address      String
  municipality String
  postCode     String
  lat          Float?
  lng          Float?

  @@unique([koId, stStavbe, stDelaStavbe])
  @@map("properties")
}

model Building {
  id                    String   @id @default(cuid())
  eidStavba             Int      @unique
  koId                  Int
  stStavbe              Int
  yearBuilt             Int?
  yearFacadeRenovated   Int?
  yearRoofRenovated     Int?
  floors                Int?
  units                 Int?
  grossArea             Float?
  electricity           Boolean  @default(false)
  gas                   Boolean  @default(false)
  water                 Boolean  @default(false)
  sewage                Boolean  @default(false)
  constructionType      String?
  buildingType          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  parts BuildingPart[]

  @@unique([koId, stStavbe])
  @@map("buildings")
}

model BuildingPart {
  id            String   @id @default(cuid())
  eidDelStavbe  Int      @unique
  eidStavba     Int
  partNumber    Int
  area          Float?
  usableArea    Float?
  useType       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  building Building @relation(fields: [eidStavba], references: [eidStavba])

  @@map("building_parts")
}

model EnergyCertificate {
  id                String   @id @default(cuid())
  certificateId     String   @unique
  koId              Int
  stStavbe          Int
  stDelaStavbe      Int?
  issueDate         DateTime
  validUntil        DateTime
  energyClass       String
  type              String?
  heatingNeed       Float?
  deliveredEnergy   Float?
  totalEnergy       Float?
  electricEnergy    Float?
  primaryEnergy     Float?
  co2Emissions      Float?
  conditionedArea   Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([koId, stStavbe, stDelaStavbe])
  @@map("energy_certificates")
}

model Transaction {
  id            String   @id @default(cuid())
  koId          Int
  stStavbe      Int
  stDelaStavbe  Int?
  price         Float
  pricePerM2    Float?
  area          Float?
  date          DateTime
  type          String?
  municipality  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([koId, stStavbe, stDelaStavbe])
  @@map("transactions")
}

model LeadEmail {
  id        String   @id @default(cuid())
  email     String
  naslov    String
  createdAt DateTime @default(now())

  @@map("lead_emails")
}

model DeliStavbNamembnost {
  eidDelStavbe     String @id
  vrstaNamembnosti Int?   // VRSTA_DEJANSKE_RABE_DEL_ST_ID šifra

  @@map("deli_stavb_namembnost")
}

model EvidencaVrednotenja {
  id                Int      @id @default(autoincrement())
  eidDelStavbe      String   @unique
  posplosenaVrednost Float?
  vrednostNaM2      Float?
  idModel           String?  // STA, HIS, GAR, PPL, PPP...
  letoIzgradnje     Int?
  povrsina          Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("evidenca_vrednotenja")
}
